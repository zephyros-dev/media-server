FROM docker.io/caddy:2.11.1-builder-alpine@sha256:fe87cb6d0e91af49085e86406c9c0d67fb594416aada53576677231397d68601 AS builder
RUN --mount=type=cache,target=/go/pkg,sharing=locked \
    xcaddy build \
    --with github.com/caddy-dns/porkbun \
    --with github.com/mholt/caddy-dynamicdns

FROM docker.io/caddy:2.11.1-alpine@sha256:3b2a0196e0687279c14c27adff9fc6b44acfa318dbb97eaebe385bdf99e5364c
COPY --from=builder /usr/bin/caddy /usr/bin/caddy
